<launch>
  <arg name="color_topic" default="/camera/color/image_raw"/>
  <arg name="aligned_depth_topic" default="/camera/aligned_depth_to_color/image_raw"/>
  <arg name="camera_info_topic" default="/camera/color/camera_info"/>
  <arg name="odom_topic" default="/vins_fusion/imu_propagate"/>
  <arg name="vins_extrinsic_topic" default="/vins_fusion/extrinsic"/>
  <arg name="depth_to_color_topic" default="/camera/extrinsics/depth_to_color"/>
  <arg name="depth_to_infra1_topic" default="/camera/extrinsics/depth_to_infra1"/>
  <arg name="goal_topic" default="/control/ego_position"/>
  <arg name="execution_enabled" default="true"/>
  <arg name="llm_model" default="gpt-5.2"/>
  <arg name="llm_reasoning_effort" default="$(optenv SMPF_LLM_REASONING_EFFORT low)"/>
  <arg name="follow_metric_frame_max_age_sec" default="1.0"/>
  <arg name="follow_metric_odom_skew_sec" default="0.08"/>
  <arg name="follow_sam_timeout_sec" default="0.75"/>

  <node pkg="smpf_bridge" type="smpf_bridge.py" name="smpf_bridge" output="screen" clear_params="true">
    <param name="color_topic" value="$(arg color_topic)"/>
    <param name="aligned_depth_topic" value="$(arg aligned_depth_topic)"/>
    <param name="camera_info_topic" value="$(arg camera_info_topic)"/>
    <param name="odom_topic" value="$(arg odom_topic)"/>
    <param name="vins_extrinsic_topic" value="$(arg vins_extrinsic_topic)"/>
    <param name="depth_to_color_topic" value="$(arg depth_to_color_topic)"/>
    <param name="depth_to_infra1_topic" value="$(arg depth_to_infra1_topic)"/>
    <param name="goal_topic" value="$(arg goal_topic)"/>
    <param name="planning_yaw_topic" value="/planning/goal_yaw_deg"/>
    <param name="execution_enabled" value="$(arg execution_enabled)"/>
    <param name="llm_model" value="$(arg llm_model)"/>
    <param name="llm_reasoning_effort" value="$(arg llm_reasoning_effort)"/>
    <param name="command_topic" value="/smpf/task_command"/>
    <param name="control_topic" value="/smpf/task_control"/>
    <param name="runtime_enable_topic" value="/smpf/execution_enable"/>
    <param name="status_topic" value="/smpf/status"/>
    <param name="dry_run_plan_topic" value="/smpf/dry_run_plan"/>
    <param name="debug_image_topic" value="/smpf/debug/annotated_image"/>
    <param name="debug_depth_topic" value="/smpf/debug/depth_image"/>
    <param name="debug_spheres_topic" value="/smpf/debug/object_spheres"/>
    <param name="frame_timeout_sec" value="1.0"/>
    <param name="sync_slop_sec" value="0.08"/>
    <param name="sphere_safety_margin_m" value="0.30"/>
    <param name="path_clearance_margin_m" value="0.05"/>
    <param name="memory_association_distance_m" value="0.35"/>
    <param name="dynamic_memory_association_distance_m" value="1.50"/>
    <param name="fallback_standoff_m" value="0.15"/>
    <param name="min_target_standoff_m" value="0.15"/>
    <param name="max_target_standoff_m" value="1.00"/>
    <param name="min_target_progress_m" value="0.10"/>
    <param name="require_target_visibility" value="true"/>
    <param name="max_body_camera_translation_m" value="0.75"/>
    <param name="max_realsense_extrinsic_translation_m" value="0.10"/>
    <param name="deterministic_fallback_enabled" value="true"/>
    <param name="completed_target_exclusion_enabled" value="true"/>
    <param name="goal_condition_validation_enabled" value="true"/>
    <param name="corridor_obstacle_filter_enabled" value="true"/>
    <param name="corridor_obstacle_margin_m" value="0.25"/>
    <param name="follow_step_limit_enabled" value="false"/>
    <param name="follow_max_step_m" value="0.50"/>
    <param name="follow_target_surface_standoff_m" value="0.15"/>
    <param name="follow_target_surface_tolerance_m" value="0.10"/>
    <param name="follow_metric_frame_max_age_sec" value="$(arg follow_metric_frame_max_age_sec)"/>
    <param name="follow_metric_odom_skew_sec" value="$(arg follow_metric_odom_skew_sec)"/>
    <param name="follow_sam_timeout_sec" value="$(arg follow_sam_timeout_sec)"/>
    <param name="require_armed_for_execution" value="false"/>
    <param name="min_execution_z" value="0.0"/>
    <param name="enable_max_speed" value="0.0"/>
    <param name="arrival_settle_sec" value="0.0"/>
    <param name="goal_tolerance_yaw_deg" value="10.0"/>
    <param name="yaw_refresh_hz" value="2.0"/>
    <param name="world_min_x" value="-20.0"/>
    <param name="world_max_x" value="20.0"/>
    <param name="world_min_y" value="-20.0"/>
    <param name="world_max_y" value="20.0"/>
    <param name="world_min_z" value="0.05"/>
    <param name="world_max_z" value="3.0"/>
  </node>
</launch>
