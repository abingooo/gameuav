GAMEUAV_WORKSPACE=/home/uav/Desktop/uav_project/gameuav
GAMEUAV_UAV_ID=uav1
GAMEUAV_ROS_SETUP=/opt/ros/noetic/setup.bash
GAMEUAV_WORKSPACE_SETUP=/home/uav/Desktop/uav_project/gameuav/devel/setup.bash
GAMEUAV_ROS_HOME=/tmp/gameuav_ros_home
GAMEUAV_ROS_LOG_DIR=/tmp/gameuav_ros_logs

# ros_to_net_gateway: ROS topics -> UDP state packets to GCS.
GAMEUAV_GATEWAY_UDP_HOST=20.0.0.172
GAMEUAV_GATEWAY_UDP_PORT=9001
GAMEUAV_GATEWAY_RATE_HZ=5.0

# net_to_ros_gateway: TCP network command -> local ROS topic / safe agent command.
GAMEUAV_GATEWAY_TCP_HOST=0.0.0.0
GAMEUAV_GATEWAY_TCP_PORT=9100
GAMEUAV_AGENT_HOST=127.0.0.1
GAMEUAV_AGENT_PORT=8765
GAMEUAV_AGENT_TOKEN=uavuavuavuav
GAMEUAV_AGENT_TIMEOUT=5.0
